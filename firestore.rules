rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['username', 'score']) &&
             data.username is string && data.username.size() <= 32 &&
             data.score is int && data.score >= 0;
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['score', 'last_solved_at', 'notif_opt_in']) &&
        incoming().score >= existing().score // Prevent score regression
      );
    }

    // --- Quiz Validation ---
    match /quizzes/{quizDate} {
      allow get: if isSignedIn() && isValidId(quizDate);
      allow list: if isSignedIn();
      allow write: if isAdmin();
      
      // Responses subcollection
      match /responses/{userId} {
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && 
                        incoming().keys().hasAll(['userId', 'quizId', 'isCorrect', 'answeredAt']) &&
                        incoming().answeredAt == request.time &&
                        exists(/databases/$(database)/documents/quizzes/$(quizDate));
      }
    }

    // --- Leaderboard ---
    match /leaderboard/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // --- Admin Review Flags ---
    match /admin_reviews/{reviewId} {
      allow read: if isSignedIn() && (isAdmin() || isOwner(resource.data.userId));
      allow create: if isSignedIn() && isOwner(incoming().userId) && incoming().isPending == true;
      allow update: if isAdmin();
    }
  }
}
